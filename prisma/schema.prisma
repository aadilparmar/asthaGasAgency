generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Employee {
  id          String   @id @default(cuid())
  name        String
  type        String
  rate        Float    @default(0)
  fixedSalary Float    @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  loans           LoanTransaction[]
  deductions      MonthlyDeduction[]
  sales           CylinderSale[]
  consumerRefills ConsumerRefill[]
}

model CylinderType {
  id           String   @id @default(cuid())
  name         String   @unique
  price        Float    @default(0)
  sellingPrice Float    @default(0)
  otpRate      Float    @default(0)
  onlineRate   Float    @default(0)
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  sales             CylinderSale[]
  consumers         Consumer[]
  refills           ConsumerRefill[]
  stockTransactions CylinderStockTransaction[]
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model LoanTransaction {
  id         String   @id @default(cuid())
  employeeId String
  amount     Float
  month      Int
  year       Int
  note       String   @default("")
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([month, year])
  @@index([employeeId, year, month])
}

model MonthlyDeduction {
  id         String   @id @default(cuid())
  employeeId String
  month      Int
  year       Int
  type       String
  amount     Float    @default(0)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year, type])
  @@index([month, year])
  @@index([type, year, month])
}

// ============================================================
// DAILY OPERATIONS (WORK BOOK) MODELS
// ============================================================

model ConnectionType {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  sales ConnectionSale[]
}

model ExpenseHead {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  expenses DailyExpense[]
}

model CommercialCustomer {
  id          String   @id @default(cuid())
  name        String
  productType String   @default("")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  transactions CommercialTransaction[]
}

model DailyOperation {
  id        String   @id @default(cuid())
  date      DateTime @unique
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales         CylinderSale[]
  connections   ConnectionSale[]
  expenses      DailyExpense[]
  denominations CashDenomination[]
  commercials   CommercialTransaction[]
  otherIncomes  OtherIncome[]
  otherExpenses OtherExpense[]
}

model CylinderSale {
  id             String         @id @default(cuid())
  dailyOpId      String
  employeeId     String
  cylinderTypeId String
  otpCount       Int            @default(0)
  onlineCount    Int            @default(0)
  nsDomCount     Int            @default(0)
  dailyOp        DailyOperation @relation(fields: [dailyOpId], references: [id], onDelete: Cascade)
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cylinderType   CylinderType   @relation(fields: [cylinderTypeId], references: [id])

  @@unique([dailyOpId, employeeId, cylinderTypeId])
}

model ConnectionSale {
  id               String         @id @default(cuid())
  dailyOpId        String
  connectionTypeId String
  nos              Int            @default(0)
  cylDpr           Float          @default(0)
  deposit          Float          @default(0)
  refill           Float          @default(0)
  sd               Float          @default(0)
  inspection       Float          @default(0)
  blueBook         Float          @default(0)
  dailyOp          DailyOperation @relation(fields: [dailyOpId], references: [id], onDelete: Cascade)
  connectionType   ConnectionType @relation(fields: [connectionTypeId], references: [id])

  @@unique([dailyOpId, connectionTypeId])
}

model DailyExpense {
  id            String         @id @default(cuid())
  dailyOpId     String
  expenseHeadId String
  particulars   String         @default("")
  amount        Float          @default(0)
  dailyOp       DailyOperation @relation(fields: [dailyOpId], references: [id], onDelete: Cascade)
  expenseHead   ExpenseHead    @relation(fields: [expenseHeadId], references: [id])
}

model CashDenomination {
  id        String         @id @default(cuid())
  dailyOpId String
  value     Int
  count     Int            @default(0)
  dailyOp   DailyOperation @relation(fields: [dailyOpId], references: [id], onDelete: Cascade)

  @@unique([dailyOpId, value])
}

model OtherIncome {
  id        String         @id @default(cuid())
  dailyOpId String
  label     String         @default("")
  amount    Float          @default(0)
  dailyOp   DailyOperation @relation(fields: [dailyOpId], references: [id], onDelete: Cascade)
}

model OtherExpense {
  id        String         @id @default(cuid())
  dailyOpId String
  label     String         @default("")
  amount    Float          @default(0)
  dailyOp   DailyOperation @relation(fields: [dailyOpId], references: [id], onDelete: Cascade)
}

model CommercialTransaction {
  id          String             @id @default(cuid())
  dailyOpId   String
  customerId  String
  productType String             @default("")
  stockOut    Int                @default(0)
  stockIn     Int                @default(0)
  amount      Float              @default(0)
  received    Float              @default(0)
  dailyOp     DailyOperation     @relation(fields: [dailyOpId], references: [id], onDelete: Cascade)
  customer    CommercialCustomer @relation(fields: [customerId], references: [id])
}

// ============================================================
// CONSUMER (DOMESTIC HOUSEHOLD) + STOCK MODELS
// ============================================================

model Consumer {
  id              String    @id @default(cuid())
  consumerNumber  String?   @unique
  bpclId          String?
  name            String
  phone           String    @default("")
  address         String    @default("")
  area            String    @default("")
  cylinderTypeId  String?
  connectionDate  DateTime?
  depositPaid     Float     @default(0)
  active          Boolean   @default(true)
  note            String    @default("")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cylinderType      CylinderType?              @relation(fields: [cylinderTypeId], references: [id])
  refills           ConsumerRefill[]
  stockTransactions CylinderStockTransaction[]
}

model ConsumerRefill {
  id              String       @id @default(cuid())
  consumerId      String
  date            DateTime
  cylinderTypeId  String
  paymentMode     String       @default("cash")
  amount          Float        @default(0)
  employeeId      String?
  note            String       @default("")
  createdAt       DateTime     @default(now())

  consumer     Consumer     @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])
  employee     Employee?    @relation(fields: [employeeId], references: [id])

  @@index([date])
  @@index([consumerId, date])
}

model CylinderStockTransaction {
  id             String       @id @default(cuid())
  date           DateTime
  cylinderTypeId String
  type           String       // purchase | delivery | empty_return | empty_dispatch | adjustment
  fullDelta      Int          @default(0)
  emptyDelta     Int          @default(0)
  consumerId     String?
  note           String       @default("")
  createdAt      DateTime     @default(now())

  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])
  consumer     Consumer?    @relation(fields: [consumerId], references: [id])

  @@index([date])
  @@index([cylinderTypeId, date])
}
